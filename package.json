    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "lint-staged": "^16.3.1",
    "simple-git-hooks": "^2.13.1",
