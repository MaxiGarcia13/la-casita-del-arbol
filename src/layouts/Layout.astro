---
import Footer from '../components/Footer.astro';
import { BUSINESS_NAME } from '../constans/business';
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = BUSINESS_NAME } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col text-charcoal bg-surface">
    <slot />
    <Footer />
  </body>
</html>
