---
import { BUSINESS_NAME } from '../constans/business';
import SocialMedia from './social-media.astro';
---

<footer
  class="mt-auto border-t border-accent/20 bg-charcoal/5 px-4 py-8 text-charcoal"
>
  <div
    class="mx-auto flex max-w-[900px] flex-col items-center gap-6 text-center"
  >
    <div>
      <p class="font-semibold text-charcoal">{BUSINESS_NAME}</p>
      <p class="mt-1 max-w-md text-sm text-charcoal/80">
        Taller de cerámica en La Plata, Argentina. Clases, talleres y eventos
        para crear piezas únicas con tus propias manos.
      </p>
    </div>

    <SocialMedia />
  </div>
</footer>
