---
import InstagramIcon from '../assets/instagram.svg';
import MusicIcon from '../assets/music.svg';
import {
  BUSINESS_NAME,
  INSTAGRAM_URL,
  SPOTIFY_URL,
} from '../constans/business';
import { LinkButton } from './link-button.tsx';
import { WhatsappLinkButton } from './whatsapp-link-button.tsx';
---

<footer
  class="mt-auto border-t border-accent/20 bg-charcoal/5 px-4 py-8 text-charcoal"
>
  <div
    class="mx-auto flex max-w-[900px] flex-col items-center gap-6 text-center"
  >
    <div>
      <p class="font-semibold text-charcoal">{BUSINESS_NAME}</p>
      <p class="mt-1 max-w-md text-sm text-charcoal/80">
        Taller de cerámica en La Plata, Argentina. Clases, talleres y eventos
        para crear piezas únicas con tus propias manos.
      </p>
    </div>

    <nav
      class="flex flex-wrap items-center justify-center gap-3"
      aria-label="Redes sociales"
    >
      <WhatsappLinkButton
        client:idle
        ariaLabel="WhatsApp - La Casita del Árbol"
      >
        WhatsApp
      </WhatsappLinkButton>
      <LinkButton
        href={INSTAGRAM_URL}
        ariaLabel="Instagram - La Casita del Árbol"
        client:idle
        className="inline-flex items-center gap-2"
      >
        <InstagramIcon
          class="size-5 shrink-0 text-current"
          aria-hidden="true"
        />
        <span>Instagram</span>
      </LinkButton>
      <LinkButton
        href={SPOTIFY_URL}
        ariaLabel="Spotify - La Casita del Árbol"
        client:idle
        className="inline-flex items-center gap-2"
      >
        <MusicIcon class="size-5 shrink-0 text-current" aria-hidden="true" />
        <span>Spotify</span>
      </LinkButton>
    </nav>
  </div>
</footer>
