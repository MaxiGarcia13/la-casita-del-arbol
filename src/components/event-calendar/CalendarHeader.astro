---
import type { CalendarDay } from './types'

interface Props {
  days: CalendarDay[]
  /** Width of the timeline column (left), so header cells align with grid */
  timelineWidth?: string
  class?: string
}

const { days, timelineWidth = '4rem', class: className = '' } = Astro.props
---

  <header class:list={['flex border-b-2 border-charcoal', className]} role='row'>
    <div
      class='border-charcoal shrink-0 border-r-2'
      aria-hidden='true'
      style={{ width: timelineWidth }}
    />
    <div class='event-calendar-header__days grid min-w-0 flex-1' role='row' style='grid-template-columns: repeat(var(--calendar-days-count, 7), 1fr);'>
      {
      days.map((day) => (
        <div
          class='border-charcoal flex items-center justify-center border-r-2 px-1 py-2 font-semibold last:border-r-0'
          key={day.key}
          role='columnheader'
          title={day.fullName ?? day.key}
        >
          {day.label}
        </div>
      ))
    }
    </div>
  </header>
