---
import type { CalendarDay, TimeSlot, CalendarEvent, NormalizedCalendarEvent } from './types'
import { normalizeCalendarEvent, getSlotDurationMinutes } from './utils'
import CalendarCell from './CalendarCell.tsx'

interface Props {
  days: CalendarDay[]
  timeSlots: TimeSlot[]
  events?: CalendarEvent[]
  slotHeight?: string
  class?: string
}

const { days, timeSlots, events = [], slotHeight = '4rem', class: className = '' } = Astro.props

const slotDurationMinutes = getSlotDurationMinutes(timeSlots)
const normalizedEvents: NormalizedCalendarEvent[] = events.map((e) => normalizeCalendarEvent(e, timeSlots))

/** Map (dayKey, slotIndex) -> event (first slot of a multi-slot event) */
function eventsByCell (eventsList: NormalizedCalendarEvent[]): Map<string, NormalizedCalendarEvent> {
  const map = new Map<string, NormalizedCalendarEvent>()
  for (const e of eventsList) {
    map.set(`${e.dayKey}-${e.startSlotIndex}`, e)
  }
  return map
}

const byCell = eventsByCell(normalizedEvents)
---

  <div
    class:list={['event-calendar-grid grid flex-1 min-w-0', className]}
    style={`--calendar-slot-height: ${slotHeight}; grid-template-columns: repeat(var(--calendar-days-count, 7), 1fr); grid-auto-rows: var(--calendar-slot-height, 4rem);`}
    role='grid'
    aria-label='Calendario de eventos'
  >
    {timeSlots.map((_, slotIndex) =>
      days.map((day) => {
        const key = `${day.key}-${slotIndex}`

        const event = byCell.get(key)

        return (
          <CalendarCell
            key={key}
            client:only='react'
            dayKey={day.key}
            slotIndex={slotIndex}
            slotDurationMinutes={slotDurationMinutes}
            event={event ? { id: event.id, title: event.title, description: event.description, spanSlots: event.spanSlots, offsetMinutes: event.offsetMinutes, durationMinutes: event.durationMinutes } : undefined}
          />
        )
      })
    )}
  </div>

    <style>
    .event-calendar-grid :global(.event-calendar-cell) {
      grid-row: span 1;
    }
    </style>
