---
const {
  href,
  target = '_blank',
  rel = 'noopener noreferrer', class: className = '',
  ariaLabel,
} = Astro.props;
---
  <a
    href={href}
    target={target}
    rel={rel}
    class={`${className} inline-flex items-center justify-center gap-2 rounded-lg border-2 px-4 py-2.5`}
    aria-label={ariaLabel}
  >
    <slot />
  </a>
