---
import type {
  CalendarEvent,
  UpcomingEvent,
} from '../components/event-calendar';
import Contact from '../components/contact.astro';
import {
  buildTimeSlots,
  EventCalendar,
  getHourAndMinute,
  getStartTimeFromStartDate,
} from '../components/event-calendar';
import EventPreviewCard from '../components/event-preview-card.astro';
import Header from '../components/header.astro';
import { BUSINESS_NAME } from '../constans/business';
import Layout from '../layouts/layout.astro';
import { formatWeekParam, getWeekStart } from '../utils/date';

const baseUrl = Astro.url.origin;
const weekParam = Astro.url.searchParams.get('week');
const weekStart = weekParam
  ? getWeekStart(new Date(weekParam))
  : getWeekStart(new Date());
const sampleEventsUrl = new URL('/api/sample-events.json', baseUrl);
sampleEventsUrl.searchParams.set('week', formatWeekParam(weekStart));

const [upcomingRes, sampleRes] = await Promise.all([
  fetch(new URL('/api/upcoming-events.json', baseUrl).href),
  fetch(sampleEventsUrl.href),
]);

if (!upcomingRes.ok || !sampleRes.ok) {
  throw new Error('Failed to fetch events from API');
}

const upcomingEvents: UpcomingEvent[] = await upcomingRes.json();
const sampleEvents: CalendarEvent[] = await sampleRes.json();

const hasCalendarEvents = sampleEvents.length > 0;
const startHour = hasCalendarEvents
  ? Math.min(
      ...sampleEvents.map(
        event =>
          getHourAndMinute(getStartTimeFromStartDate(event.startDate)).hour,
      ),
    )
  : 8;
const endHour = hasCalendarEvents
  ? Math.max(
      ...sampleEvents.map((event) => {
        const { hour } = getHourAndMinute(
          getStartTimeFromStartDate(event.startDate),
        );
        return hour + (event.durationMinutes ?? 0) / 60 + 1;
      }),
    )
  : 18;

const timeSlots = buildTimeSlots(startHour - 1, endHour, 60);
---

<Layout title={BUSINESS_NAME}>
  <main
    class="mx-auto flex min-h-screen max-w-[900px] flex-col gap-10 p-4 pb-10 md:p-0 md:pb-10"
  >
    <Header />

    <Contact />

    <h2 class="text-2xl font-bold" id="lessons-calendar">Clases</h2>
    <EventCalendar
      client:only="react"
      events={sampleEvents}
      timeSlots={timeSlots}
    />

    <h2 class="text-2xl font-bold" id="events-calendar">Eventos</h2>
    <ul class="flex flex-col gap-4" aria-label="Próximos eventos y novedades">
      {
        upcomingEvents.map(event => (
          <li>
            <EventPreviewCard event={event} />
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
