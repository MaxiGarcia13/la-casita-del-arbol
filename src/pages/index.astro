---
import type {
  CalendarEvent,
  UpcomingEvent,
} from '../components/event-calendar';
import Contact from '../components/contact.astro';
import {
  buildTimeSlots,
  EventCalendar,
  getHourAndMinute,
} from '../components/event-calendar';
import EventPreviewCard from '../components/event-preview-card.astro';
import Header from '../components/header.astro';
import { BUSINESS_NAME } from '../constans/business';
import Layout from '../layouts/Layout.astro';

const upcomingEvents: UpcomingEvent[] = [
  {
    title: 'Taller de cerámica para principiantes',
    description:
      'Un fin de semana para aprender las bases del torno y la mano. Incluye materiales y horneado.',
    dateLabel: 'Próximamente',
    ctaLabel: 'Quiero más información',
    ctaMessage:
      'Hola, me interesa el taller de cerámica para principiantes. ¿Cuándo es y cómo me inscribo?',
  },
  {
    title: 'Curso intensivo de verano',
    description:
      'Una semana de inmersión en cerámica. Niveles inicial e intermedio.',
    dateLabel: 'Enero 2026',
    ctaLabel: 'Consultar',
  },
  {
    title: 'Noche de cerámica y vino',
    description:
      'Una tarde para crear tu pieza mientras disfrutás un buen vino. Ideal para regalar o para hacer algo distinto.',
    dateLabel: 'Por confirmar',
  },
];

const sampleEvents: CalendarEvent[] = [
  {
    id: '1',
    dayKey: 'mar',
    startTime: '10:15',
    durationMinutes: 60,
    title: 'Clase cerámica',
    description: `
    Turno mañana, 10:15 - 11:15 de 2 horas.

    Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
    Lorem ipsum dolor sit amet consectetur adipisicing elit. Quisquam, quos.
    `,
    totalSlots: 10,
    slotsOccupied: 9,
    type: 'lesson',
  },
  {
    id: '2',
    dayKey: 'jue',
    startTime: '12:00',
    durationMinutes: 120,
    title: 'Taller',
    description: '2 horas',
    totalSlots: 10,
    slotsOccupied: 10,
    type: 'event',
  },
  {
    id: '3',
    dayKey: 'vie',
    startTime: '14:00',
    durationMinutes: 240,
    title: 'Curso intensivo',
    description: '3 horas',
  },
  {
    id: '4',
    dayKey: 'mar',
    startTime: '18:30',
    durationMinutes: 120,
    title: 'Clase 18:30',
    description: 'Con minutos',
  },
];

const startHour = Math.min(
  ...sampleEvents.map(event => getHourAndMinute(event.startTime).hour),
);

const endHour = Math.max(
  ...sampleEvents.map((event) => {
    const { hour } = getHourAndMinute(event.startTime);

    return hour + (event.durationMinutes ?? 0) / 60 + 1;
  }),
);

const timeSlots = buildTimeSlots(startHour - 1, endHour, 60);
---

<Layout title={BUSINESS_NAME}>
  <main
    class="mx-auto flex min-h-screen max-w-[900px] flex-col gap-10 p-4 pb-10 md:p-0 md:pb-10"
  >
    <Header />

    <Contact />

    <h2 class="text-2xl font-bold" id="lessons-calendar">Clases</h2>
    <EventCalendar events={sampleEvents} timeSlots={timeSlots} />

    <h2 class="text-2xl font-bold" id="events-calendar">Eventos</h2>
    <ul class="flex flex-col gap-4" aria-label="Próximos eventos y novedades">
      {
        upcomingEvents.map(event => (
          <li>
            <EventPreviewCard event={event} />
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
